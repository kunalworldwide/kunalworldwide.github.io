---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutContent from '../components/sections/AboutContent';
---

<BaseLayout title="About" description="Kunal Das is a Developer Advocate and Cloud Native Consultant at CAST AI, specializing in Kubernetes cost optimization and CNCF community leadership across APAC. 8+ years experience, 25+ conference talks.">
  <!-- Header -->
  <section class="pt-32 pb-8 px-4 sm:px-6 lg:px-8 animated-gradient text-white">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
        Kunal Das — Developer Advocate & Cloud Native Consultant
      </h1>
      <p class="text-xl opacity-90 max-w-2xl mx-auto">
        Bengaluru, India · CAST AI · CNCF Community Leader
      </p>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <AboutContent client:load />
  </section>
</BaseLayout>
